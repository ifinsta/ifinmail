# === Secrets & Credentials (CRITICAL — never bake into Docker images) ===
.env
provisioning/.env
provisioning/docker/dkim/*.key
provisioning/docker/dkim/*.pub
provisioning/docker/certs/

# === Python artifacts ===
__pycache__/
*.py[cod]
*.so
*.egg-info/
dist/
build/
.eggs/

# === Static & Media (collected at runtime via shared volume) ===
staticfiles/
media/

# === Virtual environments ===
.venv/
venv/
env/

# === IDE & Editor ===
.idea/
.vscode/
*.swp
*.swo
*~

# === OS artifacts ===
.DS_Store
Thumbs.db

# === Logs & coverage ===
logs/
*.log
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# === Git (not needed in app container) ===
.git/
.gitignore
.gitattributes

# === Backups (never in source tree, but safety) ===
backups/

# === Docker infrastructure (not needed in app image) ===
provisioning/docker/Dockerfile
provisioning/docker/docker-compose.yml
provisioning/docker/postfix/
provisioning/docker/dovecot/
provisioning/docker/rspamd/
provisioning/docker/nginx/
provisioning/docker/init-db.sh

# === Provisioning scripts (not needed in app image) ===
provisioning/scripts/

# === Misc ===
Makefile
*.md
