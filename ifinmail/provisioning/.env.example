# ifinmail provisioning environment variables
# Copy to .env and fill in your values. NEVER commit .env to version control.

# --- Domain ---
DOMAIN=example.com
MAIL_HOSTNAME=mail.example.com
ADMIN_EMAIL=admin@example.com

# --- CoreDNS (DNS server integration) ---
COREDNS_IP=127.0.0.1

# --- PostgreSQL ---
POSTGRES_ADMIN_PASSWORD=change_me_admin_password
DOVECOT_DB_PASSWORD=change_me_dovecot_password
POSTFIX_DB_PASSWORD=change_me_postfix_password

# --- Django ---
SECRET_KEY=change_me_django_secret_key
DJANGO_ALLOWED_HOSTS=example.com,mail.example.com

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- DKIM ---
DKIM_SELECTOR=default

# --- Backup ---
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPT=false

# --- Monitor thresholds ---
MONITOR_QUEUE_WARN=50
MONITOR_QUEUE_CRITICAL=200
MONITOR_CERT_WARN_DAYS=30
MONITOR_CERT_CRITICAL_DAYS=7
